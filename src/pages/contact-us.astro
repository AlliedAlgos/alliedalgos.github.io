---
import Layout from '../layouts/Layout.astro';
import { parse } from 'smol-toml';
import { readFileSync } from 'fs';

// Data fetching
const raw = readFileSync('./src/data/discord.toml', 'utf-8');
const { webhook_url } = parse(raw);

const title = "Contact | Allied Algorithms Robotics";
const description = "Get in touch with Allied Algorithms FLL Team 58590. Reach out for technical collaborations, sponsorships, or general robotics inquiries.";
---

<Layout title={title} description={description}>

    <section class="relative pt-32 pb-16 text-center overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(59,130,246,0.08),transparent_70%)]"></div>
        <div class="relative z-10 max-w-4xl mx-auto px-6">
            <span class="text-blue-500 font-bold tracking-[0.4em] text-xs uppercase mb-6 block">Communication Channel</span>
            <h1 class="text-6xl md:text-8xl font-black tracking-tighter italic text-white leading-none mb-6">
                GET IN <br><span class="text-blue-500">TOUCH.</span>
            </h1>
        </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 mb-32">
        <div class="flex flex-col lg:flex-row gap-12 items-start">
            
            <div class="w-full lg:w-1/4 flex flex-col gap-6 sticky top-32">
                <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-600 mb-2 ml-2">Direct Links</p>
                
                <a href="https://github.com/AlliedAlgos" target="_blank" 
                   class="group flex items-center gap-6 p-8 bg-zinc-900/40 border border-white/5 rounded-3xl hover:border-blue-500/50 hover:bg-blue-500/5 transition-all">
                    <i class="fa-brands fa-github text-4xl text-zinc-500 group-hover:text-white transition-colors"></i>
                    <div>
                        <span class="block text-[10px] font-black uppercase tracking-widest text-zinc-500">Code</span>
                        <span class="text-white font-bold italic tracking-tight">GitHub</span>
                    </div>
                </a>

                <a href="https://instagram.com/alliedalgorithms" target="_blank" 
                   class="group flex items-center gap-6 p-8 bg-zinc-900/40 border border-white/5 rounded-3xl hover:border-pink-500/50 hover:bg-pink-500/5 transition-all">
                    <i class="fa-brands fa-instagram text-4xl text-zinc-500 group-hover:text-pink-500 transition-colors"></i>
                    <div>
                        <span class="block text-[10px] font-black uppercase tracking-widest text-zinc-500">Social</span>
                        <span class="text-white font-bold italic tracking-tight">Instagram</span>
                    </div>
                </a>

                <a href="mailto:contact@alliedalgos.org" 
                   class="group flex items-center gap-6 p-8 bg-zinc-900/40 border border-white/5 rounded-3xl hover:border-blue-400/50 hover:bg-blue-400/5 transition-all">
                    <i class="fa-solid fa-envelope text-4xl text-zinc-500 group-hover:text-blue-400 transition-colors"></i>
                    <div>
                        <span class="block text-[10px] font-black uppercase tracking-widest text-zinc-500">Endpoint</span>
                        <span class="text-white font-bold italic tracking-tight">Email</span>
                    </div>
                </a>
            </div>

            <div class="w-full lg:w-3/4">
                <div class="bg-zinc-900/40 backdrop-blur-xl border border-white/5 rounded-[3rem] p-8 md:p-16 shadow-2xl">
                    <form id="contactForm" class="space-y-10">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div>
                                <label for="name" class="block mb-3 text-[10px] font-bold uppercase tracking-widest text-zinc-600 ml-1">Identity</label>
                                <input type="text" id="name" name="name" placeholder="Name / Team Name" required
                                       class="w-full p-5 bg-white/[0.02] border border-white/8 rounded-2xl text-white placeholder-zinc-800 focus:outline-none focus:border-blue-500 focus:bg-blue-500/[0.03] transition-all" />
                            </div>
                            <div>
                                <label for="email" class="block mb-3 text-[10px] font-bold uppercase tracking-widest text-zinc-600 ml-1">Digital Mail</label>
                                <input type="email" id="email" name="email" placeholder="email@address.com" required
                                       class="w-full p-5 bg-white/[0.02] border border-white/8 rounded-2xl text-white placeholder-zinc-800 focus:outline-none focus:border-blue-500 focus:bg-blue-500/[0.03] transition-all" />
                            </div>
                        </div>

                        <div>
                            <label for="message" class="block mb-3 text-[10px] font-bold uppercase tracking-widest text-zinc-600 ml-1">Message Brief</label>
                            <textarea id="message" name="message" rows="8" placeholder="How can we collaborate?" required
                                      class="w-full p-5 bg-white/[0.02] border border-white/8 rounded-2xl text-white placeholder-zinc-800 focus:outline-none focus:border-blue-500 focus:bg-blue-500/[0.03] transition-all resize-none"></textarea>
                        </div>

                        <button type="submit"
                                class="w-full py-6 bg-blue-600 hover:bg-blue-500 hover:-translate-y-1 text-white font-black text-xs uppercase tracking-[0.4em] rounded-2xl transition-all shadow-xl shadow-blue-600/20 active:scale-[0.98]">
                            Transmit Data
                        </button>
                    </form>
                    <p id="status" class="mt-8 text-center hidden text-[10px] font-bold uppercase tracking-widest"></p>
                </div>
            </div>

        </div>
    </section>

</Layout>

<script define:vars={{ webhookUrl: webhook_url }}>
    // [Keeping your existing Discord webhook logic here...]
</script>