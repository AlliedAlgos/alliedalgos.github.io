---
import Layout from '../layouts/Layout.astro';
import { parse } from 'smol-toml';
import { readFileSync } from 'fs';
import SponsorReel from '../components/SponsorReel.astro'; 

const sponsorsRaw = readFileSync('./src/data/sponsors.toml', 'utf-8');
const { sponsors } = parse(sponsorsRaw);

const title = "Allied Algorithms | Wilton's FLL Robotics Team 58590";
const description = "Representing Wilton, CT in FIRST LEGO League. 7,700+ global views. We combine competitive excellence with an open-source philosophy.";
---

<Layout title={title} description={description}>
    <div class="flex flex-col">
        
        <section class="relative min-h-screen flex items-center pt-32 overflow-hidden order-1">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,var(--color-blue-500/0.05),transparent_70%)]"></div>
            
            <div class="max-w-7xl mx-auto px-6 w-full relative z-10">
                <div class="fade-up inline-flex items-center gap-3 px-4 py-1.5 rounded-full border border-zinc-500/20 bg-zinc-500/5 mb-10">
                    <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
                    <span class="text-[10px] font-black uppercase tracking-[0.4em] text-zinc-400">Wilton, CT · Team 58590</span>
                </div>

                <h1 class="fade-up text-6xl md:text-[10rem] font-black italic tracking-tighter leading-[0.85] uppercase mb-12 text-white break-words">
                    Allied <br />
                    <span class="text-blue-500">Algorithms.</span>
                </h1>
                <p class="fade-up text-xl text-zinc-400 mb-12 md:text-[3.5rem] font-black italic tracking-tighter leading-[0.8] uppercase">
                    Where Engineering Meets Creativity
                </p>
                
                <div class="fade-up inline-flex flex-wrap items-center gap-6 md:gap-10 p-8 md:p-10 bg-zinc-900/40 border border-white/5 rounded-[3rem] backdrop-blur-xl mb-16 shadow-2xl">
                    <div class="text-left">
                        <span class="block text-[10px] font-black uppercase tracking-[0.4em] text-zinc-600 mb-2">Combined Global Reach</span>
                        <span class="text-4xl md:text-5xl font-black italic text-white tracking-tighter">
                            <span id="view-count" data-target="14891">0</span> <span class="text-blue-500 t ext-xl md:text-2xl ml-1 uppercase">Views</span>
                        </span>
                    </div>
                    <div class="h-12 w-px bg-white/10 hidden md:block"></div>
                    <div class="flex items-center gap-6">
                        <div class="flex -space-x-3">
                            {['youtube', 'facebook', 'instagram', 'globe'].map((icon) => {
                            // Determine if it's a brand or a standard solid icon
                            const isBrand = icon !== 'globe';
                            const prefix = isBrand ? 'fa-brands' : 'fa-solid';

                            return (
                                <div 
                                data-icon={icon}
                                class="w-10 h-10 rounded-full bg-zinc-800 border-2 border-zinc-950 flex items-center justify-center text-sm text-zinc-400"
                                >
                                <i class={`${prefix} fa-${icon}`}></i>
                                </div>
                            );
                            })}
                        </div>
                        </div>
                </div>

                <div class="fade-up flex flex-wrap gap-8 mb-24">
                    <a href="/seasons/" class="px-12 py-6 bg-blue-600 text-white font-black text-xs uppercase tracking-[0.4em] rounded-full hover:bg-blue-500 transition-all shadow-xl shadow-blue-600/20">
                        Explore Journey
                    </a>
                    <a href="https://robotics-catalyst.org/donate/allied-algorithms" class="px-12 py-6 border border-zinc-800 hover:border-white text-white font-black text-xs uppercase tracking-[0.4em] rounded-full transition-all">
                        Support Our Team
                    </a>
                </div>
            </div>
        </section>

        <section class="py-20 bg-zinc-950 order-2">
            <SponsorReel sponsors={sponsors} />
        </section>

        <section class="max-w-7xl mx-auto px-6 py-24 md:py-40 order-3 lg:order-5">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
                <div class="fade-up">
                    <span class="text-blue-500 font-black uppercase tracking-[0.4em] text-xs mb-6 block">The Competition</span>
                    <h2 class="text-5xl md:text-7xl font-black italic text-white uppercase leading-none mb-8 tracking-tighter">
                        FIRST LEGO <br><span class="text-zinc-700">League.</span>
                    </h2>
                    <p class="text-zinc-400 text-lg leading-relaxed font-light mb-10 max-w-lg">
                        FIRST® LEGO® League (FLL) is a global STEM program that introduces science, technology, engineering, and math through hands-on learning.
                    </p>
                    <div class="grid grid-cols-2 gap-8 border-t border-white/5 pt-10">
                        <div>
                            <span class="block text-white font-black italic text-2xl mb-1 uppercase">Innovation</span>
                            <p class="text-zinc-600 text-xs font-bold uppercase tracking-widest">Project Research</p>
                        </div>
                        <div>
                            <span class="block text-white font-black italic text-2xl mb-1 uppercase">Robotics</span>
                            <p class="text-zinc-600 text-xs font-bold uppercase tracking-widest">Autonomous Systems</p>
                        </div>
                    </div>
                </div>
                <div class="fade-up aspect-square rounded-[3rem] md:rounded-[4rem] overflow-hidden bg-zinc-900 border border-white/5 relative group">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-600/10 to-transparent z-10"></div>
                    <div class="p-10 md:p-16 relative z-20 h-full flex flex-col justify-end">
                        <i class="fa-solid fa-microchip text-6xl text-blue-500 mb-8"></i>
                        <h3 class="text-3xl font-black italic text-white uppercase mb-4">6 Seasons of Excellence</h3>
                        <p class="text-zinc-400 font-light">From Masterpiece to Submerged, we've built a legacy of technical documentation.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="bg-slate-950 py-12 rounded-[3rem] md:rounded-[5rem] mx-1 md:mx-2 overflow-hidden border border-white/5 order-4">
            <div class="max-w-6xl mx-auto px-6">
                <div class="text-center mb-16">
                    <span class="text-slate-500 font-black uppercase tracking-[0.4em] text-[10px] mb-4 block">Our Engineering Culture</span>
                    <h2 class="text-5xl md:text-7xl font-black italic uppercase leading-none tracking-tighter mb-6 text-white">
                        Open <br><span class="text-blue-500">Source.</span>
                    </h2>
                    <p class="text-slate-400 text-lg max-w-xl mx-auto font-light leading-relaxed">
                        We believe in the "Allied" part of our name. We publish our technical logs and CAD to elevate the entire FLL community.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {[
                        { icon: 'code-branch', title: 'Frameworks', desc: 'Reusable code architectures for precision and reliability.' },
                        { icon: 'cube', title: 'CAD Assets', desc: '3D models shared to assist teams in mastering structural integrity.' },
                        { icon: 'book-open', title: 'Public Logs', desc: 'A full archive of our design iterations and breakthroughs.' }
                    ].map((item) => (
                        <div class="space-y-4 group p-6 bg-slate-900/40 rounded-[1rem] border border-white/5 hover:border-blue-500/30 transition-all">
                            <div class="w-10 h-12 bg-slate-800 rounded-xl flex items-center justify-center text-blue-400 text-xl group-hover:scale-110 transition-transform">
                                <i class={`fa-solid fa-${item.icon}`}></i>
                            </div>
                            <h4 class="text-md font-black italic uppercase text-white">{item.title}</h4>
                            <p class="font-light text-ms text-slate-400 leading-snug">{item.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section class="py-24 order-6">
            <div id="donate" class="fade-up relative group w-full max-w-6xl mx-auto px-6">
                <div class="absolute -inset-2 bg-gradient-to-r from-blue-600 via-slate-500 to-zinc-400 rounded-[4rem] blur opacity-10 group-hover:opacity-25 transition duration-1000"></div>
                <div class="relative flex flex-col lg:flex-row items-stretch bg-zinc-900 border border-white/10 rounded-[3rem] md:rounded-[4rem] overflow-hidden backdrop-blur-md">
                    <div class="w-full lg:w-2/5 bg-zinc-950/50 flex flex-col items-center justify-center p-12 border-b lg:border-b-0 lg:border-r border-white/5 text-center">
                        <div class="w-24 h-24 bg-blue-600/20 rounded-3xl flex items-center justify-center mb-6">
                            <i class="fa-solid fa-trophy text-5xl text-blue-500"></i>
                        </div>
                        <p class="text-white font-black italic text-2xl uppercase tracking-tighter mb-2">Road to Worlds</p>
                        <p class="text-zinc-500 text-xs font-bold uppercase tracking-widest">Houston, Texas • 2026</p>
                    </div>

                    <div class="w-full lg:w-3/5 p-12 lg:p-16 flex flex-col justify-center">
                        <h2 class="text-4xl lg:text-6xl font-black italic text-white uppercase mb-6 tracking-tighter leading-none">
                            Support Our <span class="text-blue-500">Team.</span>
                        </h2>
                        <p class="text-zinc-400 text-lg mb-10 leading-relaxed font-light">
                            Help <strong>Allied Algorithms</strong> represent Connecticut at the FLL World Championship. Your contribution supports our technical innovation and covers essential travel costs.
                        </p>
                        <a href="https://alliedalgorithms.org/donate" target="_blank" class="w-full sm:w-auto text-center px-10 py-6 bg-blue-600 text-white font-black uppercase tracking-widest text-xs rounded-2xl hover:bg-blue-500 transition-all transform hover:scale-105 shadow-xl shadow-blue-600/20">
                            Donate to Our Team
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>

<script is:inline>
    function animateValue(obj, start, end, duration) {
        let startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            obj.innerHTML = Math.floor(progress * (end - start) + start).toLocaleString();
            if (progress < 1) window.requestAnimationFrame(step);
        };
        window.requestAnimationFrame(step);
    }

    const observerOptions = { threshold: 0.1 };
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                if (entry.target.contains(document.getElementById('view-count'))) {
                    const counter = document.getElementById('view-count');
                    if (counter && counter.innerText === "0") {
                        const target = parseInt(counter.getAttribute('data-target'));
                        animateValue(counter, 0, target, 2000);
                    }
                }
            }
        });
    }, observerOptions);

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>

<style>
    .fade-up {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-up.visible {
        opacity: 1;
        transform: translateY(0);
    }
    html {
        scroll-behavior: smooth;
    }
</style>