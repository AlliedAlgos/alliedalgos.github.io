---
import Layout from '../../layouts/Layout.astro';
import { parse } from 'smol-toml';
import { readFileSync } from 'fs';

// Data Fetching
const raw = readFileSync('./src/data/seasons.toml', 'utf-8');
const { seasons } = parse(raw);

// SEO Strategy: Wilton, FLL Team 58590, and Social Proof
const title = "FLL Seasons & Engineering History | Allied Algorithms Wilton, CT";
const description = "Explore Team 58590's journey. With over 7,792 views across YT, FB, Insta, and Web, Allied Algorithms is Wilton's premier student-led robotics team.";
---

<Layout title={title} description={description}>
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [{
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://alliedalgos.org/"
      },{
        "@type": "ListItem",
        "position": 2,
        "name": "Seasons",
        "item": "https://alliedalgos.org/seasons/"
      }]
    }
    </script>

    <section class="relative pt-32 pb-20 text-center overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(59,130,246,0.08),transparent_70%)]"></div>
        
        <div class="relative z-10 max-w-4xl mx-auto px-6">
            <span class="text-blue-500 font-bold tracking-[0.4em] text-[10px] uppercase mb-6 block">Wilton Team 58590 // Mission Log</span>
            
            <h1 class="text-6xl md:text-8xl font-black tracking-tighter italic text-white leading-none mb-12">
                ALL <br><span class="text-blue-500">SEASONS.</span>
            </h1>

            <div class="inline-flex flex-wrap justify-center items-center gap-4 md:gap-8 p-6 md:p-8 bg-zinc-900/50 border border-white/5 rounded-[2.5rem] backdrop-blur-md">
                <div class="text-left">
                    <span class="block text-[10px] font-black uppercase tracking-[0.3em] text-zinc-500 mb-1">Combined Global Reach</span>
                    <span class="text-3xl md:text-4xl font-black italic text-white tracking-tighter">
                        7,792 <span class="text-blue-500 text-xl md:text-2xl ml-1 uppercase">Views</span>
                    </span>
                </div>
                
                <div class="h-10 w-px bg-white/10 hidden md:block"></div>

                <div class="flex items-center gap-4">
                    <div class="flex -space-x-2">
                        <div class="w-9 h-9 rounded-full bg-zinc-800 border-2 border-zinc-950 flex items-center justify-center text-xs text-zinc-400">
                            <i class="fa-brands fa-youtube"></i>
                        </div>
                        <div class="w-9 h-9 rounded-full bg-zinc-800 border-2 border-zinc-950 flex items-center justify-center text-xs text-zinc-400">
                            <i class="fa-brands fa-facebook"></i>
                        </div>
                        <div class="w-9 h-9 rounded-full bg-zinc-800 border-2 border-zinc-950 flex items-center justify-center text-xs text-zinc-400">
                            <i class="fa-brands fa-instagram"></i>
                        </div>
                        <div class="w-9 h-9 rounded-full bg-zinc-800 border-2 border-zinc-950 flex items-center justify-center text-xs text-zinc-400">
                            <i class="fa-solid fa-globe"></i>
                        </div>
                    </div>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-zinc-500 leading-tight">
                        YT / FB / <br>INSTA / WEB
                    </span>
                </div>
            </div>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 mb-40 space-y-20">
        {seasons.map((season, i) => (
            <a href={`/seasons/${season.slug}/`} 
               class="fade-up group relative block w-full rounded-[3.5rem] border border-white/5 bg-zinc-900/20 transition-all duration-700 hover:border-blue-500/40 hover:bg-zinc-900/40 hover:shadow-[0_0_80px_-20px_rgba(59,130,246,0.2)] overflow-hidden">
                
                <div class="flex flex-col lg:flex-row items-stretch min-h-[500px]">
                    
                    <div class="relative w-full lg:w-3/5 overflow-hidden">
                        <img 
                            src={season.cover_photo} 
                            alt={`${season.theme} FLL Season - Allied Algorithms`}
                            class="w-full h-full object-cover transition-all duration-1000 opacity-60 grayscale-[0.4] group-hover:opacity-100 group-hover:grayscale-0 group-hover:scale-105"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-zinc-950/90 via-zinc-950/20 to-transparent"></div>
                        
                        {i === 0 && (
                            <div class="absolute top-10 left-10 px-5 py-2 bg-blue-600 text-white text-[10px] font-black uppercase tracking-[0.4em] rounded-full z-20 shadow-2xl animate-pulse">
                                Current Campaign
                            </div>
                        )}
                    </div>

                    <div class="w-full lg:w-2/5 p-12 md:p-20 flex flex-col justify-center relative">
                        <div class="flex items-center gap-6 mb-10">
                            <div class="h-[1px] w-16 bg-blue-500/30 group-hover:w-24 group-hover:bg-blue-500 transition-all duration-700"></div>
                            <span class="text-blue-500 font-mono text-sm tracking-[0.4em] font-bold">{season.year}</span>
                        </div>

                        <h2 class="text-6xl md:text-7xl font-black italic text-white uppercase leading-[0.85] mb-8 tracking-tighter group-hover:text-blue-400 transition-colors duration-500">
                            {season.theme}
                        </h2>

                        <p class="text-zinc-500 text-lg leading-relaxed mb-12 font-light max-w-sm group-hover:text-zinc-300 transition-colors duration-500">
                            {season.description || "Engineering robust robotics solutions and driving community impact across Wilton schools."}
                        </p>

                        <div class="flex flex-wrap gap-2 mb-16">
                            {season.awards.map(award => (
                                <span class="px-4 py-2 bg-white/5 border border-white/10 text-zinc-500 text-[10px] font-black uppercase tracking-widest rounded-xl group-hover:border-blue-500/30 group-hover:text-blue-400 transition-all duration-500">
                                    {award}
                                </span>
                            ))}
                        </div>

                        <div class="flex items-center gap-5">
                            <div class="w-14 h-14 rounded-full border border-white/10 flex items-center justify-center group-hover:border-blue-500 group-hover:bg-blue-500 transition-all duration-500">
                                <i class="fa-solid fa-chevron-right text-sm text-white group-hover:translate-x-1 transition-transform"></i>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-[10px] font-black uppercase tracking-[0.5em] text-zinc-600 group-hover:text-blue-500 transition-colors">Access Logs</span>
                                <span class="text-white font-bold italic uppercase tracking-tighter group-hover:text-white transition-colors">Technical Review</span>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        ))}
    </section>

    <section class="max-w-6xl mx-auto px-6 mb-32 text-center">
        <div class="h-px w-full bg-gradient-to-r from-transparent via-white/10 to-transparent mb-20"></div>
        <p class="text-[10px] font-black uppercase tracking-[0.6em] text-zinc-600 mb-4">Continuing the Legacy</p>
        <h3 class="text-white font-black italic uppercase text-3xl tracking-tighter">Powered by Community. Driven by Innovation.</h3>
    </section>
</Layout>

<style>
    /* Ensure smooth reveal on scroll */
    .fade-up {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-up.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    // Reveal Observer
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>