---
import { parse } from 'smol-toml';
import { readFileSync } from 'fs';

const raw = readFileSync('./src/data/sponsors.toml', 'utf-8');
const { sponsors } = parse(raw);

const colClass = sponsors.length === 1 ? 'grid-cols-1' : sponsors.length === 2 ? 'grid-cols-2' : 'grid-cols-3';
---

<footer class="bg-zinc-900/40 backdrop-blur-2xl py-12 px-6 md:px-12 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">

            <!-- Official Resources -->
            <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-4">Official Resources</p>
                <h3 class="text-2xl font-bold tracking-tighter italic text-white mb-5">Useful Links</h3>
                <ul class="space-y-3 text-sm text-zinc-500">
                    <li>
                        <a href="https://www.firstlegoleague.org/" target="_blank" class="hover:text-white transition duration-300 flex items-center gap-2 justify-center md:justify-start">
                            <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
                            FIRST LEGO League
                        </a>
                    </li>
                    <li>
                        <a href="https://www.firstinspires.org/" target="_blank" class="hover:text-white transition duration-300 flex items-center gap-2 justify-center md:justify-start">
                            <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
                            FIRST Robotics
                        </a>
                    </li>
                </ul>

                <div class="mt-8 flex flex-wrap gap-2 justify-center md:justify-start">
                    <a href="/" class="text-[10px] text-zinc-600 hover:text-zinc-400 transition-colors">Home</a>
                    <span class="text-zinc-800">·</span>
                    <a href="/about-us" class="text-[10px] text-zinc-600 hover:text-zinc-400 transition-colors">About</a>
                    <span class="text-zinc-800">·</span>
                    <a href="/seasons" class="text-[10px] text-zinc-600 hover:text-zinc-400 transition-colors">Seasons</a>
                    <span class="text-zinc-800">·</span>
                    <a href="/contact-us" class="text-[10px] text-zinc-600 hover:text-zinc-400 transition-colors">Contact</a>
                    <span class="text-zinc-800">·</span>
                    <a href="/docs" class="text-[10px] text-zinc-600 hover:text-zinc-400 transition-colors">Docs</a>
                </div>
            </div>

            <!-- Connect -->
            <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-4">Socials</p>
                <h3 class="text-2xl font-bold tracking-tighter italic text-white mb-5">Connect With Us</h3>
                <div class="flex justify-center md:justify-start gap-3">
                    <a href="https://github.com/AlliedAlgos" target="_blank"
                       class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-500 hover:text-white hover:border-white/20 hover:bg-white/10 transition-all duration-300">
                        <i class="fab fa-github"></i>
                    </a>
                    <a href="https://www.instagram.com/allied.algorithm/" target="_blank"
                       class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-500 hover:text-pink-500 hover:border-pink-500/30 hover:bg-pink-500/10 transition-all duration-300">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a href="https://www.facebook.com/profile.php?id=61585941825799" target="_blank"
                       class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-500 hover:text-blue-500 hover:border-blue-500/30 hover:bg-blue-500/10 transition-all duration-300">
                        <i class="fab fa-facebook"></i>
                    </a>
                    <a href="https://www.youtube.com/@alliedalgorithms" target="_blank"
                       class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-zinc-500 hover:text-red-500 hover:border-red-500/30 hover:bg-red-500/10 transition-all duration-300">
                        <i class="fab fa-youtube"></i>
                    </a>
                </div>

                <div class="mt-6 inline-flex items-center gap-3 px-4 py-3 rounded-xl bg-white/5 border border-white/5">
                    <i class="fa-solid fa-envelope text-zinc-500 text-xs"></i>
                    <a href="mailto:alliedalgorithms@gmail.com" class="text-xs text-zinc-400 hover:text-white transition-colors">alliedalgorithms@gmail.com</a>
                </div>

                <div class="mt-4">
                    <a href="https://robotics-catalyst.org/donate/allied-algorithms" target="_blank"
                       class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-[11px] font-black uppercase rounded-full transition-all tracking-wider">
                        <i class="fa-solid fa-heart text-[10px]"></i>
                        Donate
                    </a>
                </div>
            </div>

            <!-- Sponsors -->
            <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-4">Partners</p>
                <h3 class="text-2xl font-bold tracking-tighter italic text-white mb-5">Sponsors</h3>

                <div class={`grid gap-3 p-4 bg-white/5 rounded-2xl border border-white/5 min-h-[100px] ${colClass}`}>
                    {sponsors.length === 0 ? (
                        <p class="text-zinc-600 text-[10px] font-bold uppercase tracking-widest col-span-full text-center self-center">No sponsors yet</p>
                    ) : (
                        sponsors.map(s => (
                            <a href={s.website_url} target="_blank"
                               class="h-20 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center p-3 grayscale hover:grayscale-0 hover:bg-white/10 hover:border-white/20 transition-all duration-300">
                                <img src={s.logo_url} alt={s.name} class="max-h-full max-w-full object-contain" />
                            </a>
                        ))
                    )}
                </div>
            </div>

        </div>

        <!-- Bottom bar -->
        <div class="border-t border-white/5 mt-12 pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-xs text-zinc-600">&copy; 2026 Allied Algorithms. All rights reserved.</p>
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-800">Proud members of FIRST & FLL</p>
        </div>
    </div>
</footer>