---
// Navbar.astro - God Tier V2 (The Final Polish)
---

<style is:global>
  :root {
    --nav-pill-width: 580px;
    --accent-blue: 59, 130, 246;
    --ease-heavy: cubic-bezier(0.25, 1, 0.3, 1);
    --ease-spring: cubic-bezier(0.3, 1.5, 0.5, 1);
  }

  /* 1. THE DYNAMIC ISLAND CORE */
  #navContainer {
    transition: 
      width 0.8s var(--ease-heavy),
      height 0.6s var(--ease-heavy),
      border-radius 0.7s var(--ease-heavy),
      background 0.5s ease,
      padding 0.7s var(--ease-heavy),
      box-shadow 0.5s ease;
    will-change: width, border-radius, transform;
  }

  /* 2. SPATIAL STATE MAPPING */
  .nav-state-full {
    width: 95%;
    max-width: 1200px;
    border-radius: 24px;
    padding: 0 32px;
    background: rgba(10, 10, 12, 0.6);
  }

  .nav-state-pill {
    width: var(--nav-pill-width);
    border-radius: 999px;
    padding: 0 12px;
    background: rgba(10, 10, 12, 0.9);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  /* 3. LIQUID INDICATOR */
  #navIndicator {
    position: absolute;
    height: 36px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    transition: all 0.5s var(--ease-spring);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }

  /* 4. MEGA PANEL SPATIAL LOGIC */
  #megaPanel {
    transition: 
      opacity 0.4s ease, 
      transform 0.6s var(--ease-heavy), 
      width 0.8s var(--ease-heavy),
      border-radius 0.8s var(--ease-heavy);
    transform-origin: top center;
  }

  .nav-state-full #megaPanel {
    width: 100%;
    border-radius: 0 0 32px 32px;
  }

  .nav-state-pill #megaPanel {
    width: 500px;
    border-radius: 32px;
  }

  /* 5. GHOST BRANDING */
  .brand-anim {
    transition: all 0.6s var(--ease-heavy);
    white-space: nowrap;
    overflow: hidden;
  }
  .nav-state-pill .brand-anim {
    width: 0;
    opacity: 0;
    margin: 0;
    transform: translateX(-20px);
  }

  /* 6. SPOTLIGHT GRID EFFECT */
  .spotlight-grid {
    position: relative;
  }
  .spotlight-grid::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      400px circle at var(--mouse-x) var(--mouse-y),
      rgba(var(--accent-blue), 0.1),
      transparent 80%
    );
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }
  .spotlight-grid:hover::before { opacity: 1; }

  .glass-blur {
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
</style>

<div class="fixed top-[-100px] left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-blue-500/10 blur-[120px] pointer-events-none z-[9999]"></div>

<header id="navWrapper" class="fixed inset-x-0 top-0 z-[10000] flex justify-center pt-10">
  <nav id="navContainer" class="nav-state-full glass-blur h-16 flex items-center justify-between relative">
    
    <a href="/" class="flex items-center gap-3 z-20 group relative pl-2">
      <div class="w-10 h-10 flex-shrink-0 relative">
        <div class="absolute inset-0 bg-blue-500/20 blur-xl rounded-full scale-0 group-hover:scale-150 transition-transform duration-700"></div>
        <img src="/images/Allied-Algorithms_logo.svg" class="w-full h-full relative transition-transform duration-500 group-hover:rotate-12" alt="Logo" />
      </div>
      <div class="brand-anim flex flex-col">
        <span class="text-white font-black italic tracking-tighter text-xl leading-none">ALLIED</span>
        <span class="text-blue-500 font-bold text-[9px] tracking-[0.3em] leading-none mt-1">ALGORITHMS</span>
      </div>
    </a>

    <div id="navLinks" class="hidden md:flex items-center gap-1 relative z-10 px-2">
      <div id="navIndicator"></div>
      {['About', 'Seasons', 'Contact'].map(item => (
        <a href={`/${item.toLowerCase()}`} class="nav-item px-5 py-2 text-sm font-bold text-zinc-400 hover:text-white transition-colors relative z-10">
          {item}
        </a>
      ))}

      <div class="relative group" id="megaTrigger">
        <button class="nav-item flex items-center gap-2 px-5 py-2 text-sm font-bold text-zinc-400 group-hover:text-white transition-all z-10">
          Projects
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-width="3" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>
    </div>

    <div class="flex items-center gap-3 z-20 pr-2">
      <a href="/donate" class="magnetic-btn px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-[11px] font-black uppercase tracking-widest rounded-full transition-all hover:shadow-[0_0_25px_rgba(59,130,246,0.5)] active:scale-95">
        Donate
      </a>
      <button id="mobileToggle" class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 glass-blur rounded-full group">
        <span class="w-5 h-[2px] bg-white transition-all group-hover:w-6"></span>
        <span class="w-4 h-[2px] bg-white self-end mr-2.5"></span>
      </button>
    </div>

    <div id="megaPanel" class="absolute top-[100%] left-1/2 -translate-x-1/2 opacity-0 invisible pointer-events-none glass-blur overflow-hidden z-[5] mt-4 spotlight-grid">
      <div class="p-8 grid grid-cols-2 gap-4">
        {[
          { icon: 'fa-robot', title: 'Robot', desc: 'Hardware Specs', color: 'blue' },
          { icon: 'fa-microchip', title: 'AAC', desc: 'Control Logic', color: 'purple' },
          { icon: 'fa-route', title: 'Pathing', desc: 'Auto Planning', color: 'green' },
          { icon: 'fa-book', title: 'Docs', desc: 'API Reference', color: 'orange' }
        ].map(p => (
          <a href="#" class="group/card flex items-start gap-4 p-4 rounded-2xl hover:bg-white/5 border border-transparent hover:border-white/10 transition-all z-10">
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center bg-${p.color}-500/10 text-${p.color}-400 group-hover/card:scale-110 transition-transform`}>
              <i class={`fa-solid ${p.icon} text-xl`}></i>
            </div>
            <div>
              <div class="text-sm font-bold text-white mb-0.5 group-hover/card:text-blue-400 transition-colors">{p.title}</div>
              <p class="text-[11px] text-zinc-500 leading-tight">{p.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  class AlliedNav {
    private nav = document.getElementById('navContainer') as HTMLElement;
    private indicator = document.getElementById('navIndicator') as HTMLElement;
    private megaTrigger = document.getElementById('megaTrigger') as HTMLElement;
    private megaPanel = document.getElementById('megaPanel') as HTMLElement;
    private navLinks = document.getElementById('navLinks') as HTMLElement;
    private items = document.querySelectorAll('.nav-item');
    private isPill = false;
    private megaActive = false;

    constructor() {
      this.init();
    }

    private init() {
      if (!this.nav || !this.megaTrigger) return;

      window.addEventListener('scroll', () => {
        requestAnimationFrame(() => this.handleScroll());
      }, { passive: true });

      this.items.forEach(item => {
        item.addEventListener('mouseenter', (e) => this.moveIndicator(e.target as HTMLElement));
      });

      this.navLinks.addEventListener('mouseleave', () => {
        this.indicator.style.opacity = '0';
      });

      let timer: number;
      this.megaTrigger.addEventListener('mouseenter', () => {
        clearTimeout(timer);
        this.showMega();
      });

      this.nav.addEventListener('mouseleave', () => {
        timer = window.setTimeout(() => this.hideMega(), 200);
      });

      // Spotlight effect logic
      this.megaPanel.addEventListener('mousemove', (e) => {
        const rect = this.megaPanel.getBoundingClientRect();
        this.megaPanel.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
        this.megaPanel.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
      });

      const donateBtn = document.querySelector('.magnetic-btn') as HTMLElement;
      if (donateBtn) {
        donateBtn.addEventListener('mousemove', (e) => {
          const r = donateBtn.getBoundingClientRect();
          const x = e.clientX - r.left - r.width/2;
          const y = e.clientY - r.top - r.height/2;
          donateBtn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
        });
        donateBtn.addEventListener('mouseleave', () => donateBtn.style.transform = '');
      }

      this.handleScroll();
    }

    private handleScroll() {
      const y = window.scrollY;
      const threshold = 60;

      if (y > threshold && !this.isPill) {
        this.nav.classList.replace('nav-state-full', 'nav-state-pill');
        this.isPill = true;
        if (this.megaActive) this.syncMegaPosition();
      } else if (y <= threshold && this.isPill) {
        this.nav.classList.replace('nav-state-pill', 'nav-state-full');
        this.isPill = false;
        if (this.megaActive) this.syncMegaPosition();
      }
    }

    private moveIndicator(el: HTMLElement) {
      const rect = el.getBoundingClientRect();
      const parentRect = this.navLinks.getBoundingClientRect();
      this.indicator.style.opacity = '1';
      this.indicator.style.width = `${rect.width}px`;
      this.indicator.style.left = `${rect.left - parentRect.left}px`;
    }

    private syncMegaPosition() {
      this.megaPanel.style.transform = `translateX(-50%) translateY(${this.isPill ? '16px' : '0px'})`;
    }

    private showMega() {
      this.megaActive = true;
      this.megaPanel.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
      this.megaPanel.classList.add('opacity-100', 'visible', 'pointer-events-auto');
      this.syncMegaPosition();
    }

    private hideMega() {
      this.megaActive = false;
      this.megaPanel.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
      this.megaPanel.classList.add('opacity-0', 'invisible', 'pointer-events-none');
    }
  }

  new AlliedNav();
</script>